# ================================================
#  GreenWheels — Environment Variables
#  COPY THIS FILE:  copy .env.example .env.local
#  Then fill in your values in .env.local
#  NEVER commit .env.local to Git
# ================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GreenWheels
NODE_ENV=development

# MongoDB Atlas
# IMPORTANT: If SRV gives ECONNREFUSED error —
# Go to Atlas → Network Access → Add IP Address → Allow Access From Anywhere (0.0.0.0/0)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/greenwheels?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=replacethiswith32charslongrandomstring
NEXTAUTH_URL=http://localhost:3000

# Admin Credentials (set by developer only — no registration page)
ADMIN_EMAIL=admin@greenwheels.in
ADMIN_PASSWORD=replacewithaverystrongpassword

# Google OAuth (Week 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — Email OTP (free tier — 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@greenwheels.in

# Razorpay — Test mode never expires
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Cloudinary — Image uploads (free 25GB)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ================================================
#  WEEK 1 MINIMUM — only fill these 2 to run:
#  MONGODB_URI  and  NEXTAUTH_SECRET
# ================================================